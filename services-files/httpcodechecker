[Unit]
Description=CodeChecker
After=network.target
StartLimitIntervalSec=1800
StartLimitBurst=8

[Service]
PIDFile=/var/run/httpcodechecker.pid
User=httpcodechecker
Group=httpcodechecker
WorkingDirectory=/home/httpcodechecker/http-code-checker
ExecStart=/home/httpcodechecker/.local/bin/uv run gunicorn codechecker.wsgi:application --workers 2 --max-requests 100 --threads=5 --bind=0.0.0.0 --log-level=debug --timeout 300

# make sure log directory exists and owned by syslog
PermissionsStartOnly=true
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=CodeChecker
StandardError=inherit
Restart=on-failure
RestartSec=180s

[Install]
WantedBy=multi-user.target
